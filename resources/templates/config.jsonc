{
    "MapChanger": {
        "Rtv": {
            "Enabled": true,
            "EnabledInWarmup": false,
            "NominationEnabled": true,
            "MinPlayers": 0,
            "MinRounds": 0,
            "ChangeMapImmediately": true,
            "MapsToShow": 3,
            "VoteDuration": 30,
            "VotePercentage": 60,
            "VoteCooldownTime": 300
        },
        "Nomination": {
            // Filter menu to a single map type. Options: "surf", "bhop", or leave blank for all maps.
            // When set, only maps whose Id or Name starts with "<type>_" are shown.
            "MapType": "",
            // Comma-separated list of tiers to include in the nomination menu.
            // Example: "1,2,3" shows only T1–T3 maps. Leave blank to show all tiers.
            "IncludeTiers": ""
        },
        "Votemap": {
            "Enabled": true,
            "VotePercentage": 60,
            "ChangeMapImmediately": true,
            "MinPlayers": 0
        },
        "EndOfMap": {
            "Enabled": true,
            "MapsToShow": 6,
            "VoteDuration": 30,
            "ChangeMapDelay": 5,
            "TriggerSecondsBeforeEnd": 120,
            "TriggerRoundsBeforeEnd": 4,
            "AllowExtend": true,
            "ExtendTimeStep": 15,
            "ExtendRoundStep": 0,
            "ExtendLimit": 3
        },
        "ExtendMap": {
            "Enabled": true,
            "EnabledInWarmup": false,
            "MinPlayers": 0,
            "MinRounds": 0,
            "VotePercentage": 60,
            // Permission flag required to use the extend / !ve command.
            // Leave empty to allow everyone. Example: "@css/vip".
            "Permission": "",
            // Seconds that must pass after a successful extend vote before
            // another extend vote can start. Set to 0 to disable.
            "CooldownDuration": 180
        },
        "MapsInCooldown": 3,
        "Commands": {
            "Rtv": "rtv",
            "UnRtv": "unrtv",
            "Nominate": "nominate,nom,yd",
            "Timeleft": "timeleft",
            "Nextmap": "nextmap",
            "Votemap": "votemap",
            "Revote": "revote",
            "SetNextMap": "setnextmap",
            "Extend": "ext,extendmap,ve,voteextend",
            "MapsVote": "mapsvote",
            "MapList": "maplist,maps",
            "AddMap": "addmap",
            "RemoveMap": "removemap",
            "CycleMenu": "cyclemenu,mapcycle"
        },
        "Cycle": {
            "Enabled": true,
            "RandomOrder": false,
            "AddMapPermission": "admin.changemap",
            "RemoveMapPermission": "admin.changemap",
            "CycleMenuPermission": "admin.changemap"
        },
        "AllowSpectatorsToVote": false,
